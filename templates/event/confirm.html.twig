{# templates/event/confirm.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Réservation confirmée{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card shadow-sm">
            <div class="card-body py-5">
                <div style="font-size:5rem;">🎉</div>
                <h2 class="mt-3 text-success">Réservation confirmée !</h2>
                <hr>
                <p class="lead">Merci <strong>{{ reservation.name }}</strong> !</p>
                <p>Votre réservation pour l'événement</p>
                <h5 class="text-primary">{{ reservation.event.title }}</h5>
                <p class="text-muted">
                    📍 {{ reservation.event.location }}<br>
                    🗓️ {{ reservation.event.date|date('d/m/Y à H:i') }}
                </p>
                <hr>
                <p class="small text-muted">
                    Un email de confirmation sera envoyé à <strong>{{ reservation.email }}</strong>
                </p>
                <a href="{{ path('event_index') }}" class="btn btn-primary mt-3">
                    ← Voir d'autres événements
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}