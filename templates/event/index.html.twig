{# templates/event/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Événements disponibles{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">📅 Événements à venir</h1>
    <span class="badge bg-secondary fs-6">{{ events|length }} événement(s)</span>
</div>

{% if events is empty %}
    <div class="alert alert-info">
        Aucun événement disponible pour le moment. Revenez bientôt !
    </div>
{% else %}
    <div class="row g-4">
        {% for event in events %}
        <div class="col-md-4">
            <div class="card h-100">
                {% if event.image %}
                    <img src="{{ asset('uploads/' ~ event.image) }}" class="card-img-top" style="height:200px;object-fit:cover;" alt="{{ event.title }}">
                {% else %}
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:200px;">
                        <span style="font-size:4rem;">🎪</span>
                    </div>
                {% endif %}
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">{{ event.title }}</h5>
                    <p class="card-text text-muted small">
                        📍 {{ event.location }}<br>
                        🗓️ {{ event.date|date('d/m/Y à H:i') }}
                    </p>
                    <p class="card-text flex-grow-1">{{ event.description|slice(0, 100) }}…</p>
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <span class="badge bg-success badge-seats">🪑 {{ event.seats }} places</span>
                        <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-primary btn-sm">
                            Voir & Réserver →
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}