{% extends 'base.html.twig' %}

{% block title %}Événements{% endblock %}

{% block body %}
<section class="hero">
    <div class="container">
    <p style="font-size:12px; text-align:center; 
            padding:10px;  
            letter-spacing:1px;">
  +17k lieux disponibles · Déjà choisis par +1M de participants
</p>

        <h1><i class="fas fa-calendar-alt"></i> Nos Événements</h1>
        <p style="color: var(--gray-100);">Découvrez une sélection d'événements exceptionnels et réservez votre place en quelques clics</p>
     </div>
    <div class="hero-decoration" style="width:300px;height:300px;top:-100px;left:-100px;"></div>
    <div class="hero-decoration" style="width:200px;height:200px;bottom:-50px;right:10%;animation-delay:2s;"></div>
</section>

<section class="events-section">
    <div class="container">
        {% if events is empty %}
            <div class="no-events">
                <i class="fas fa-calendar-xmark"></i>
                <h3>Aucun événement disponible</h3>
                <p>Revenez bientôt pour découvrir nos prochains événements !</p>
            </div>
        {% else %}
            <div class="events-grid">
                {% for event in events %}
                    {% set isPast = event.date < date() %}
                    {% set isFull = event.seats <= 0 %}
                    {% set day = event.date|date('d') %}
                    {% set month = event.date|date('M')|upper %}

                    <article class="event-card">
                        <div class="event-image">
                            {% if event.image %}
                                <img src="{{ asset('uploads/' ~ event.image) }}" alt="{{ event.title }}">
                            {% else %}
                                <div class="event-image-placeholder">
                                    <i class="fas fa-calendar-alt"></i>
                                </div>
                            {% endif %}

                            <div class="event-date-badge">
                                <span class="day">{{ day }}</span>
                                <span class="month">{{ month }}</span>
                            </div>

                            {# <span class="event-badge {{ isPast ? 'past' : 'upcoming' }}">
                                {{ isPast ? 'Terminé' : 'À venir' }}
                            </span> #}
                            <span class="event-badge {{ isPast ? 'past' : (isFull ? 'past' : 'upcoming') }}">
    {{ isPast ? 'Terminé' : (isFull ? 'Complet' : 'À venir') }}
</span>
                        </div>

                        <div class="event-content">
                            <h3>{{ event.title }}</h3>

                            <div class="event-meta">
                                <span class="meta-item">
                                    <i class="fas fa-map-marker-alt"></i>
                                    {{ event.location }}
                                </span>
                                <span class="meta-item">
                                    <i class="fas fa-calendar"></i>
                                    {{ event.date|date('d/m/Y à H:i') }}
                                </span>
                                <span class="meta-item">
                                    <i class="fas fa-users"></i>
                                    {{ event.seats }} places
                                </span>
                            </div>

                            <p class="event-description">
                                {{ event.description|slice(0, 120) }}{{ event.description|length > 120 ? '…' : '' }}
                            </p>

                            {# <div class="event-actions">
                                <span class="seats-badge">
                                    <i class="fas fa-ticket-alt"></i> {{ event.seats }} places
                                </span>
                                <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-primary">
                                    <span>Voir & Réserver</span>
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </div> #}
                            <div class="event-actions">
    {% if isPast %}
        <span class="seats-badge" style="background: transparent; color: var(--gray-600);">
            <i class="fas fa-clock"></i> Terminé
        </span>
        <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-secondary">
            <span>Voir détails</span>
            <i class="fas fa-arrow-right"></i>
        </a>
    {% elseif isFull %}
        <span class="seats-badge" style="background: transparent; color: var(--danger);">
            <i class="fas fa-ban"></i> Complet
        </span>
        <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-secondary">
            <span>Voir détails</span>
            <i class="fas fa-arrow-right"></i>
        </a>
    {% else %}
        <span class="seats-badge">
            <i class="fas fa-ticket-alt"></i> {{ event.seats }} places
        </span>
        <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-primary">
            <span>Voir & Réserver</span>
            <i class="fas fa-arrow-right"></i>
        </a>
    {% endif %}
</div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}