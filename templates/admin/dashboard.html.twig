{# templates/admin/dashboard.html.twig #}
{% extends 'admin/base_admin.html.twig' %}
{% block title %}Dashboard Admin{% endblock %}

{% block admin_body %}
<h2 class="mb-4">📊 Tableau de bord</h2>

<div class="row g-4 mb-5">
    <div class="col-md-6">
        <div class="card text-white bg-primary">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-title">Événements</h6>
                    <h2 class="mb-0">{{ totalEvents }}</h2>
                </div>
                <span style="font-size:3rem;">🎪</span>
            </div>
            <div class="card-footer">
                <a href="{{ path('admin_event_index') }}" class="text-white">Gérer →</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card text-white bg-success">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-title">Réservations</h6>
                    <h2 class="mb-0">{{ totalReservations }}</h2>
                </div>
                <span style="font-size:3rem;">📋</span>
            </div>
            <div class="card-footer">
                <a href="{{ path('admin_reservation_index') }}" class="text-white">Voir toutes →</a>
            </div>
        </div>
    </div>
</div>

<h5>📅 Événements récents</h5>
<table class="table table-hover">
    <thead class="table-dark">
        <tr><th>Titre</th><th>Date</th><th>Lieu</th><th>Places</th><th>Actions</th></tr>
    </thead>
    <tbody>
        {% for event in latestEvents %}
        <tr>
            <td>{{ event.title }}</td>
            <td>{{ event.date|date('d/m/Y') }}</td>
            <td>{{ event.location }}</td>
            <td><span class="badge bg-info">{{ event.seats }}</span></td>
            <td>
                <a href="{{ path('admin_event_edit', {id: event.id}) }}" class="btn btn-sm btn-warning">✏️</a>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}