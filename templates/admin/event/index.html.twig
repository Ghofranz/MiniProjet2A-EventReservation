{% extends 'admin/base_admin.html.twig' %}
{% block title %}Gestion des événements - EventRes{% endblock %}

{% block admin_body %}
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-serif font-bold text-white mb-2 flex items-center gap-3">
             <i class="fas fa-calendar-alt text-blue-400"></i> Événements
        </h1>
        <p class="text-slate-400">Gérez tous les événements de la plateforme</p>
    </div>

    <a href="{{ path('admin_event_new') }}" class="bg-gradient-to-r from-blue-600 to-cyan-500 hover:from-blue-500 hover:to-cyan-400 text-white font-semibold py-3 px-6 rounded-xl shadow-[0_10px_20px_rgba(59,130,246,0.3)] transition transform hover:-translate-y-1 flex items-center gap-2 border border-blue-400/50">
        <i class="fas fa-plus-circle"></i> Nouvel événement
    </a>
</div>

<div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-2xl">
    <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50">
        <h2 class="text-xl font-serif font-bold text-slate-900 flex items-center gap-3">
            <i class="fas fa-list text-blue-600"></i> Liste des événements
        </h2>
        <span class="bg-white border border-slate-200 px-3 py-1 rounded-full text-xs font-bold text-slate-600 shadow-sm">{{ events|length }} événement(s)</span>
    </div>

    {% if events is empty %}
        <div class="p-16 text-center flex flex-col items-center">
            <div class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mb-6 text-slate-400 text-4xl shadow-inner border border-slate-100">
                <i class="fas fa-calendar-plus"></i>
            </div>
            <h3 class="text-2xl font-serif font-bold text-slate-900 mb-2">Aucun événement</h3>
            <p class="text-slate-500 mb-8 max-w-sm font-medium">Commencez par créer votre premier événement pour lancer les réservations.</p>
            <a href="{{ path('admin_event_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-xl shadow-[0_10px_20px_rgba(37,99,235,0.3)] transition transform hover:-translate-y-1 flex items-center gap-2">
                <i class="fas fa-plus"></i> Créer un événement
            </a>
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-white border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500 font-bold">
                        <th class="p-4 pl-6">Image</th>
                        <th class="p-4">Titre</th>
                        <th class="p-4">Date</th>
                        <th class="p-4">Lieu</th>
                        <th class="p-4 text-center">Places</th>
                        <th class="p-4 text-center">Réservations</th>
                        <th class="p-4 pr-6 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    {% for event in events %}
                        <tr class="hover:bg-slate-50 transition group">
                            <td class="p-4 pl-6">
                                {% if event.image %}
                                    <img src="{{ asset('uploads/' ~ event.image) }}" alt="{{ event.title }}" class="w-16 h-12 object-cover rounded-lg shadow-sm border border-slate-200 group-hover:scale-105 transition">
                                {% else %}
                                    <div class="w-16 h-12 bg-slate-100 rounded-lg flex items-center justify-center text-slate-400 border border-slate-200 shadow-inner">
                                        <i class="fas fa-calendar-alt"></i>
                                    </div>
                                {% endif %}
                            </td>
                            <td class="p-4 font-bold text-slate-800">{{ event.title }}</td>
                            <td class="p-4">
                                <span class="block text-slate-800 font-medium">{{ event.date|date('d/m/Y') }}</span>
                                <span class="text-xs text-slate-500 font-medium"><i class="fas fa-clock text-blue-500 mr-1"></i>{{ event.date|date('H:i') }}</span>
                            </td>
                            <td class="p-4 text-slate-600 font-medium text-xs">
                                <span class="flex items-center gap-1.5 w-max"><i class="fas fa-map-marker-alt text-blue-500"></i> {{ event.location }}</span>
                            </td>
                            <td class="p-4 text-center">
                                <span class="bg-slate-100 px-3 py-1 rounded-full text-xs font-bold text-slate-700 border border-slate-200 inline-block shadow-sm">{{ event.seats }}</span>
                            </td>
                            <td class="p-4 text-center">
                                <span class="bg-emerald-50 text-emerald-700 px-3 py-1 rounded-full text-xs font-bold border border-emerald-200 inline-block shadow-sm">
                                    {{ event.reservations|length }}
                                </span>
                            </td>
                            <td class="p-4 pr-6 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-small btn-secondary" title="Voir" target="_blank">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('admin_event_edit', {id: event.id}) }}" class="btn btn-small btn-info" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post"
                                          action="{{ path('admin_event_delete', {id: event.id}) }}"
                                          style="display:inline"
                                          onsubmit="return confirm('Supprimer « {{ event.title }} » ?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete-event-' ~ event.id) }}">
            <button type="submit" class="btn btn-small btn-danger" title="Supprimer">
                <i class="fas fa-trash text-xs"></i>
            </button>
        </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}