{# templates/event/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Événements{% endblock %}

{% block body %}

{# ═══ HERO ═══ #}
<section class="hero">
    <div class="container">
        <h1><i class="fas fa-sparkles"></i> Nos Événements</h1>
        <p>Découvrez une sélection d'événements exceptionnels et réservez votre place en quelques clics</p>
    </div>
    <div class="hero-decoration" style="width:300px;height:300px;top:-100px;left:-100px;"></div>
    <div class="hero-decoration" style="width:200px;height:200px;bottom:-50px;right:10%;animation-delay:2s;"></div>
</section>

{# ═══ EVENTS GRID ═══ #}
<section class="events-section">
    <div class="container">

        {% if events is empty %}
            <div class="no-events">
                <i class="fas fa-calendar-xmark"></i>
                <h3>Aucun événement disponible</h3>
                <p>Revenez bientôt pour découvrir nos prochains événements !</p>
            </div>
        {% else %}
            <div class="events-grid">
                {% for event in events %}

                    {# Variables de statut #}
                    {% set isPast = event.date < date() %}
                    {% set day = event.date|date('d') %}
                    {% set month = event.date|date('M')|upper %}

                    <article class="event-card">

                        {# Image #}
                        <div class="event-image">
                            {% if event.image %}
                                <img src="{{ asset('uploads/' ~ event.image) }}"
                                     alt="{{ event.title }}"
                                     style="width:100%;height:100%;object-fit:cover;">
                            {% else %}
                                <div class="event-image-placeholder">
                                    <i class="fas fa-calendar-alt"></i>
                                </div>
                            {% endif %}

                            {# Badge date #}
                            <div class="event-date-badge">
                                <span class="day">{{ day }}</span>
                                <span class="month">{{ month }}</span>
                            </div>

                            {# Badge statut #}
                            <span class="event-badge {{ isPast ? 'past' : 'upcoming' }}">
                                {{ isPast ? 'Terminé' : 'À venir' }}
                            </span>
                        </div>

                        {# Contenu #}
                        <div class="event-content">
                            <h3>{{ event.title }}</h3>

                            <div class="event-meta">
                                <span class="meta-item">
                                    <i class="fas fa-map-marker-alt"></i>
                                    {{ event.location }}
                                </span>
                                <span class="meta-item">
                                    <i class="fas fa-calendar"></i>
                                    {{ event.date|date('d/m/Y à H:i') }}
                                </span>
                                <span class="meta-item">
                                    <i class="fas fa-users"></i>
                                    {{ event.seats }} places
                                </span>
                            </div>

                            <p class="event-description">
                                {{ event.description|slice(0, 120) }}{{ event.description|length > 120 ? '…' : '' }}
                            </p>

                            <div class="event-actions" style="display:flex;gap:1rem;align-items:center;margin-top:auto;">
                                <span style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.4rem 1rem;background:var(--primary-gradient);color:white;border-radius:var(--radius-full);font-size:0.85rem;font-weight:600;">
                                    <i class="fas fa-ticket-alt"></i> {{ event.seats }} places
                                </span>
                                <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-primary">
                                    <span>Voir & Réserver</span>
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>

                    </article>

                {% endfor %}
            </div>
        {% endif %}

    </div>
</section>

{% endblock %}