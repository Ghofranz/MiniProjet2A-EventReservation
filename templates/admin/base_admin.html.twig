{% extends 'base.html.twig' %}

{% block body %}
<!-- Admin Layout Container -->
<div class="flex flex-col lg:flex-row min-h-[calc(100vh-80px)] w-full bg-slate-100">
    
    <!-- Sidebar / Nav -->
    <aside class="w-full lg:w-72 flex-shrink-0 bg-white border-r border-slate-200 flex flex-col z-20 sticky top-[80px] shadow-sm" style="height: calc(100vh - 80px);">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between lg:justify-center">
            <h2 class="text-xl font-serif font-bold text-slate-800 flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center text-sm shadow-inner">
                    <i class="fas fa-shield-alt"></i>
                </div>
                 Admin Space
            </h2>
            <button id="adminMobileToggle" class="lg:hidden text-slate-500 hover:text-slate-800 transition">
                <i class="fas fa-bars"></i>
            </button>
        </div>

        <nav id="adminNavMenu" class="flex-1 overflow-y-auto px-4 py-8 hidden lg:block">
            <ul class="space-y-2">
                <li>
                    <a href="{{ path('admin_dashboard') }}" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm {% if app.request.attributes.get('_route') == 'admin_dashboard' %}bg-blue-50 text-blue-700 shadow-sm border border-blue-100{% else %}text-slate-600 hover:text-slate-900 hover:bg-slate-50{% endif %}">
                        <i class="fas fa-chart-pie w-5"></i> Vue d'ensemble
                    </a>
                </li>
                <li>
                    <div class="text-[0.65rem] font-bold text-slate-400 uppercase tracking-wider mt-6 mb-3 px-4">Gestion</div>
                    <a href="{{ path('admin_event_index') }}" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm {% if app.request.attributes.get('_route') starts with 'admin_event' %}bg-blue-50 text-blue-700 shadow-sm border border-blue-100{% else %}text-slate-600 hover:text-slate-900 hover:bg-slate-50{% endif %}">
                        <i class="fas fa-calendar-alt w-5"></i> Événements
                    </a>
                </li>
                <li>
                    <a href="{{ path('admin_reservation_index') }}" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm {% if app.request.attributes.get('_route') starts with 'admin_reservation' %}bg-blue-50 text-blue-700 shadow-sm border border-blue-100{% else %}text-slate-600 hover:text-slate-900 hover:bg-slate-50{% endif %}">
                        <i class="fas fa-ticket-alt w-5"></i> Réservations
                    </a>
                </li>
            </ul>
        </nav>

        <div class="p-4 border-t border-slate-100 hidden lg:block">
            <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm text-red-600 hover:text-red-700 hover:bg-red-50 w-full">
                <i class="fas fa-sign-out-alt w-5"></i> Déconnexion
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <!-- The user wanted dark application background with white cards. So we leave bg-slate-900 here -->
    <main class="flex-1 w-full bg-slate-900 min-h-full">
        <div class="p-6 md:p-10 max-w-7xl mx-auto space-y-8">
            {% block admin_body %}{% endblock %}
        </div>
    </main>

</div>

<script>
    document.getElementById('adminMobileToggle')?.addEventListener('click', function() {
        const menu = document.getElementById('adminNavMenu');
        menu.classList.toggle('hidden');
    });
</script>
{% endblock %}